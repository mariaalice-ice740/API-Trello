    {
      "name": "Create a board",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", () => {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const response = pm.response.json()\r",
              "\r",
              "pm.test(\"Board is created\", () => {\r",
              "pm.expect(response.closed).to.be.false;\r",
              "pm.collectionVariables.set('boardId', response.id);   \r",
              "});\r",
              "\r",
              "pm.test(\"Board is privated\", () => {\r",
              "pm.expect(response.prefs.permissionLevel).to.be.equal(\"private\"); \r",
              "});\r",
              "\r",
              "pm.test(\"Calendar is disabled\", () => {\r",
              "const calendarView = response.prefs.switcherViews.find (view => view.viewType === 'Calendar');\r",
              "pm.expect(calendarView).to.be.an('object');\r",
              "pm.expect(calendarView.enabled).to.be.false \r",
              "});\r",
              "\r",
              "pm.collectionVariables.set('boardId', response.id)"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "/*function getNumberVar(key, valorDefault = 0) {\r",
              "    let valor = pm.collectionVariables.get(key);\r",
              "    if (isNaN(valor)) {\r",
              "        return valorDefault;\r",
              "    }\r",
              "    return valor;\r",
              "}*/\r",
              "/*let boardNumber = getNumberVar('boardNumber');\r",
              "boardNumber++;*/\r",
              "\r",
              "let boardNumber = Number(pm.collectionVariables.get('boardNumber'));\r",
              "if (isNaN(boardNumber)) {\r",
              "    boardNumber = 1;\r",
              "} else {\r",
              "    boardNumber++;\r",
              "}\r",
              "pm.collectionVariables.set('boardNumber', boardNumber);\r",
              "\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
